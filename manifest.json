{
  "manifest_version": 3,
  "name": "Cardmarket Offer Filter",
  "version": "1.0.0",
  "description": "Filter Cardmarket offers by country, seller type/reputation, card condition, price, and custom blocklist/whitelist.",
  "permissions": ["storage"],
  "host_permissions": ["*://*.cardmarket.com/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Cardmarket Filter",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.cardmarket.com/*"],
      "js": ["defaults.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
